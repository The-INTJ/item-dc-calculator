{
  "name": "shard-dc-calculator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:prod": "next dev --env-file .env.production",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:install": "playwright install --with-deps chromium",
    "docs:build": "tsx scripts/build-openapi.ts",
    "docs:validate": "npm run docs:build && npx swagger-cli validate app/api/contest/openapi.json",
    "emulators": "firebase emulators:start",
    "emulators:seed": "node scripts/seed-emulator.mjs",
    "dev:emu": "next dev --env-file .env.emulators",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:indexes": "firebase deploy --only firestore:indexes",
    "deploy:firestore": "firebase deploy --only firestore"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@base-ui-components/react": "^1.0.0-alpha.6",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@fontsource/roboto": "^5.1.1",
    "@mui/material": "^6.4.2",
    "@scalar/nextjs-api-reference": "^0.9.11",
    "firebase": "^12.6.0",
    "firebase-admin": "^12.7.0",
    "next": "^16.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@next/eslint-plugin-next": "^15.5.9",
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^22.12.0",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.17.0",
    "firebase-tools": "^15.11.0",
    "globals": "^15.14.0",
    "jsdom": "^26.0.0",
    "sass": "^1.81.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.17",
    "wait-on": "^9.0.5"
  }
}
